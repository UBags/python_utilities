# =============================================================================
# Build artifacts — regenerated by `python -m build`, `setup.py`, pip install
# =============================================================================
build/
dist/
*.egg-info/
*.egg
wheels/
.eggs/
MANIFEST           # only auto-generated MANIFEST; if you write MANIFEST.in, that's NOT ignored

# =============================================================================
# Python bytecode and caches
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# =============================================================================
# Test, type-check, and coverage artifacts
# =============================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# =============================================================================
# Virtual environments — never commit these; they contain platform-specific
# binaries and the path of whoever created them
# =============================================================================
.venv/
venv/
env/
ENV/
.env/                  # the directory; the ".env" file pattern below covers the dotenv case
.python-version        # pyenv local version pin (per-developer setting)

# =============================================================================
# Secrets and local configuration — these are the security-critical ones.
# Add anything else here that holds keys, tokens, or local-only config.
# =============================================================================
.env                   # dotenv files commonly contain API keys
.env.*                 # .env.local, .env.production, etc.
!.env.example          # but keep an example file if you provide one
*.pem
*.key
secrets.json
credentials.json

# =============================================================================
# IDE and editor metadata
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store              # macOS
Thumbs.db              # Windows

# =============================================================================
# Documentation builds (Sphinx, MkDocs)
# =============================================================================
docs/_build/
site/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# Local-only development files — uncomment if you use them
# =============================================================================
# scratch/
# notes.md
# TODO.private.md